{
  "id": "/",
  "background_color": "#ffffff",
  "theme_color": "#10B981",
  "dir": "ltr",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone"
  ],
  "name": "Solar Guardian Clients Portal",
  "short_name": "Solar Guardian",
  "orientation": "any",
  "scope": "/",
  "start_url": "https://solar-guardian-clients.vercel.app/",
  "description": "Client portal for Solar Guardian's professional solar panel cleaning and maintenance services. Track your invoices, payments, and service schedules easily.",
  "theme_color": "#ffffff",
  "icons": [
    {
      "src": "https://solar-guardian-clients.vercel.app/logo.png",
      "type": "image/png",
      "sizes": "192x192",
      "isSquare": true,
      "isPng": true,
      "isWebp": false,
      "isJpg": false,
      "width": 192,
      "is512x512": false,
      "is256x256": false,
      "is192x192": true,
      "purpose": "any"
    },
     {
      "src": "https://solar-guardian-clients.vercel.app/icons.svg",
      "type": "image/svg+xml",
      "isSquare": true,
      "isPng": false,
      "isWebp": false,
      "isJpg": false,
      "width": 1920,
      "is512x512": false,
      "is256x256": false,
      "is192x192": false,
      "purpose": "any"
    }, {
       
      "src": "https://solar-guardian-clients.vercel.app/icon.png",
      "type": "image/png",
      "isSquare": true,
      "isPng": true,
      "isWebp": false,
      "isJpg": false,
      "width": 1920,
      "is512x512": false,
      "is256x256": false,
      "is192x192": false,
      "purpose": "any"
    
    },  {
      "src": "https://solar-guardian-clients.vercel.app/logo-512.png",
      "type": "image/png",
       "sizes": "512x512",
      "isSquare": true,
      "isPng": true,
      "isWebp": false,
      "isJpg": false,
      "width": 512,
      "is512x512": true,
      "is256x256": false,
      "is192x192": false,
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "View My Bills",
      "short_name": "Bills",
      "description": "Quickly view your recent invoices",
      "url": "/?tab=bills",
      "icons": [
        {
          "src": "https://solar-guardian-clients.vercel.app/logo-512.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Contact Support",
      "short_name": "Support",
      "description": "Get help from Solar Guardian",
      "url": "/?tab=profile",
      "icons": [
        {
          "src": "https://solar-guardian-clients.vercel.app/logo-512.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/?action=share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+solarguardian",
      "url": "/?route=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/?action=new_note"
  },
  "widgets": [
    {
      "name": "Next Service Widget",
      "description": "Shows your upcoming solar cleaning service",
      "tag": "next_service",
      "ms_ac_template": "widget_template.json",
      "data": "widget_data.json",
      "type": "application/json"
    }
  ],
  "categories": [
    "lifestyle"
  ]
  
}
